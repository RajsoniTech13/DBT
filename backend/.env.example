# ─────────────────────────────────────────────────────────────
# DBT Leakage Detection System - Environment Configuration
# Copy this file to .env and update values as needed
# ─────────────────────────────────────────────────────────────

# Server
PORT=5000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=dbthackathon

# Redis (also used as message broker between Node and ML service)
REDIS_HOST=redis
REDIS_PORT=6379

# Hadoop WebHDFS (namenode)
HADOOP_URL=http://hadoop-namenode:9870
HDFS_DATA_PATH=/dbt-data/dbt_merged.csv

# ML Microservice communicates via Redis queues (no direct URL needed)
# Queue 1: incoming_transactions  (Node → Redis → ML)
# Queue 2: processed_results      (ML → Redis → Node)
